# Anthropic Claude API key (required for AI Director)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs API key (required for Phase 2 voice pipeline)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Stagehand / Browserbase (optional, fallback for Claude Vision)
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# Pipeline tuning
CLAUDE_VISION_CONFIDENCE_THRESHOLD=0.7
SCENE_RECORDING_FPS=30
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
PAGE_LOAD_TIMEOUT_MS=30000
CLICK_ACTION_TIMEOUT_MS=10000
CLICK_RETRY_ATTEMPTS=2
