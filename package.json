{
  "name": "video-factory",
  "version": "0.1.0",
  "description": "CLI tool that auto-generates polished 1080p tutorial videos from URL + feature description",
  "type": "module",
  "bin": {
    "video-factory": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@browserbasehq/stagehand": "^1.13.0",
    "@remotion/bundler": "^4.0.432",
    "@remotion/renderer": "^4.0.432",
    "dotenv": "^16.4.7",
    "playwright": "^1.50.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
